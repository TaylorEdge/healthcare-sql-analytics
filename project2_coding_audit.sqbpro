<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="C:/Users/taylo/Downloads/project2_coding_audit.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1455"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="coding_audits" custom_title="0" dock_id="1" table="4,13:maincoding_audits"/><dock_state state="000000ff00000000fd00000001000000020000043c00000316fc0100000001fb000000160064006f0063006b00420072006f007700730065003101000000000000043c0000012400ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="coding_audits" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="78"/><column index="2" value="84"/><column index="3" value="66"/><column index="4" value="85"/><column index="5" value="84"/><column index="6" value="94"/><column index="7" value="156"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="Data Verification*">-- Verification of loaded data
SELECT
	COUNT(*) AS total_audits,
	SUM(CASE WHEN corrected_code IS NOT NULL THEN 1 ELSE 0 END) AS errors_found,
	SUM(CASE WHEN corrected_code IS NULL THEN 1 ELSE 0 END) AS corrected_codes,
	ROUND(100.0 * SUM(CASE WHEN corrected_code IS NOT NULL THEN 1 ELSE 0 END)
		/ COUNT(*), 1) AS overall_error_rate_pct
	FROM coding_audits;</sql><sql name="Coder Accuracy*">-- Ranks coders for accuracy
SELECT e.coder_id,
	COUNT(*) AS audits_performed,
	SUM(CASE WHEN a.corrected_code IS NULL THEN 1 ELSE 0 END) AS correct,
	SUM(CASE WHEN a.corrected_code IS NOT NULL THEN 1 ELSE 0 END) AS errors, 
	ROUND(100.0 * SUM(CASE WHEN a.corrected_code IS NULL
		THEN 1 ELSE 0 END) / COUNT(*), 1) AS accuracy_pct
FROM coding_audits a
JOIN encounters e ON a.encounter_id = e.encounter_id
GROUP BY e.coder_id
ORDER BY accuracy_pct ASC;</sql><sql name="Error Type Breakdown*">-- This query breaks down every error category by frequency
SELECT error_type,
	COUNT(*) AS error_count,
	ROUND(100.0 * COUNT(*) / SUM(COUNT(*)) OVER (), 1) AS pct_of_all_errors
FROM coding_audits
WHERE error_type IS NOT NULL
GROUP BY error_type
ORDER BY error_count DESC;</sql><sql name="Invalid Code Detection*">-- This joins the encounter data against the ICD-10 reference table to flag invalid coding. 
-- I50 -&gt; should be I50.9 or I50.32   S72.0 -&gt; S72.00A for example
SELECT
e.encounter_id,
e.encounter_date,
e.coder_id,
e.primary_icd10,
r.description,
CASE
WHEN r.valid = 0 THEN 'Invalid Code'
WHEN r.requires_7th = 1
	AND LENGTH(e.primary_icd10) &lt; 7 THEN 'Missing 7th Character'
ELSE 'OK'
END AS code_status
FROM encounters e
LEFT JOIN icd10_reference r
ON e.primary_icd10 = r.icd10_code
WHERE r.valid = 0
OR (r.requires_7th = 1 AND LENGTH(e.primary_icd10) &lt; 7)
ORDER BY e.coder_id, e.encounter_date;</sql><sql name="Monthly Accuracy Trend*">-- This query tracks coder accuracy by Month
SELECT e.coder_id,
strftime('%m-%Y', a.audit_date) AS audit_month,
COUNT(*) AS audits,
ROUND(100.0 * SUM(CASE WHEN a.corrected_code IS NULL
	THEN 1 ELSE 0 END) / COUNT(*), 1) AS accuracy_pct
FROM coding_audits a
JOIN encounters e ON a.encounter_id = e.encounter_id
GROUP BY e.coder_id, audit_month
HAVING audits &gt;= 3
ORDER BY audit_month, e.coder_id;</sql><current_tab id="4"/></tab_sql></sqlb_project>
