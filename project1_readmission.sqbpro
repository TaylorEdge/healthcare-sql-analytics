<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="project1_readmission.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2103"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="admissions" custom_title="0" dock_id="1" table="4,10:mainadmissions"/><dock_state state="000000ff00000000fd00000001000000020000046a00000316fc0100000001fb000000160064006f0063006b00420072006f007700730065003101000000000000046a0000012400ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="admissions" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="2" mode="0"/></sort><column_widths><column index="1" value="82"/><column index="2" value="70"/><column index="3" value="96"/><column index="4" value="94"/><column index="5" value="60"/><column index="6" value="300"/><column index="7" value="85"/><column index="8" value="57"/><column index="9" value="129"/><column index="10" value="89"/><column index="11" value="72"/><column index="12" value="57"/><column index="13" value="85"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="Verification of Data*">--Verifying data completeness for errors
SELECT COUNT(*) AS total_admissions FROM admissions;</sql><sql name="Admissions by Payer type*">-- This query counts how many admissions each payer type has 
-- and calculates average length of stay.
SELECT
	payer_type,
	COUNT(*) AS total_admissions,
	ROUND(AVG(los_days), 1) AS avg_los_days
FROM admissions
GROUP BY payer_type
ORDER BY total_admissions DESC;</sql><sql name="30 Day readmission flag*">-- Flags readmissions within 30 days. 
WITH ranked_admissions AS (
  SELECT
    patient_id,
    admission_date,
    discharge_date,
    drg_code,
    payer_type,
    los_days,
    discharge_disposition,
    LAG(discharge_date) OVER (
      PARTITION BY patient_id
      ORDER BY admission_date
    ) AS prior_discharge_date
  FROM admissions
),
readmit_flagged AS (
  SELECT *,
    CASE
      WHEN julianday(admission_date) - julianday(prior_discharge_date) &lt;= 30
      THEN 1 ELSE 0
    END AS is_30day_readmit
  FROM ranked_admissions
)
SELECT
  drg_code,
  payer_type,
  COUNT(*) AS total_admits,
  SUM(is_30day_readmit) AS readmissions,
  ROUND(100.0 * SUM(is_30day_readmit) / COUNT(*), 1) AS readmit_rate_pct,
  ROUND(AVG(los_days), 1) AS avg_los
FROM readmit_flagged
GROUP BY drg_code, payer_type
HAVING total_admits &gt;= 5
ORDER BY readmit_rate_pct DESC
LIMIT 15;
</sql><sql name="High Risk Patients*">-- This query identifies high risk patients readmitting multiple times
WITH ranked AS (
	SELECT 
	patient_id,
	admission_date,
	discharge_date,
	payer_type,
	los_days,
	LAG(discharge_date) OVER (
		PARTITION BY patient_id ORDER BY admission_date
	) AS prior_disch
	FROM admissions
), 
flagged AS (
	SELECT *,
		CASE WHEN julianday(admission_date) - julianday(prior_disch) &lt;= 30
			THEN 1 ELSE 0
		END AS readmit
	FROM ranked
)
SELECT	
	f.patient_id, 
	p.payer_type,
	COUNT(*) AS total_admissions,
	SUM(f.readmit) AS readmissions,
	ROUND(AVG(f.los_days), 1) AS avg_los
FROM flagged f
JOIN patients p ON f.patient_id = p.patient_id
GROUP BY f.patient_id, p.payer_type
HAVING readmissions &gt;= 2
ORDER BY readmissions DESC
LIMIT 20;</sql><current_tab id="2"/></tab_sql></sqlb_project>
